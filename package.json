{
  "name": "adadarsh23",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ad Adarsh's Music Portfolio",
  "author": "Ad Adarsh <adadarsh523@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adadarsh23/Profile-Website"
  },
  "browserslist": "defaults",
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "trailingComma": "es5",
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "vitest": {
    "test": {
      "environment": "jsdom"
    }
  },
  "vite": {
    "plugins": [
      "@vitejs/plugin-react",
      "vite-plugin-compression",
      "vite-plugin-sitemap",
      "vite-plugin-remove-console",
      "vite-plugin-pwa",
      "@vitejs/plugin-legacy"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "vite",
    "react",
    "frontend",
    "typescript",
    "web"
  ],
  "bugs": {
    "url": "https://github.com/adadarsh23/Profile-Website/issues"
  },
  "homepage": "https://github.com/adadarsh23/Profile-Website",
  "scripts": {
    "dev": "vite && npm run lighthouse-audit",
    "lighthouse-audit": "node -e \"setTimeout(()=>import('./lighthouse-audit.js'),5000)\"",
    "build": "vite build",
    "preview": "vite preview",
    "job": "node job.js",
    "lint": "eslint --ext .js,.ts,.jsx,.tsx src",
    "lint:fix": "eslint --ext .js,.ts,.jsx,.tsx src --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "gh-pages -d dist",
    "cleandist": "rimraf dist",
    "dev-tools": "node commands.cjs help",
    "clean": "node commands.cjs clean",
    "clean:modules": "rm -rf node_modules && npm install",
    "clean:vite": "rm -rf node_modules/.vite",
    "clean:npm": "npm cache clean --force",
    "clean:all": "rm -rf node_modules package-lock.json node_modules/.vite && npm install",
    "check:outdated": "npm outdated",
    "clean:cache": "node commands.cjs clean:cache",
    "fresh": "node commands.cjs fresh",
    "update:check": "node commands.cjs update:check",
    "update:all": "node commands.cjs update:all",
    "update:interactive": "node commands.cjs update:interactive",
    "update:minor": "node commands.cjs update:minor",
    "update:patch": "node commands.cjs update:patch",
    "audit": "node commands.cjs audit:check",
    "audit:fix": "node commands.cjs audit:fix",
    "analyze": "node commands.cjs analyze",
    "component": "node commands.cjs create:component",
    "page": "node commands.cjs create:page",
    "info": "node commands.cjs info",
    "help": "node commands.cjs help",
    "implementation-guide": "node IMPLEMENTATION_GUIDE.cjs",
    "enhancements": "node ENHANCEMENT_COMPLETE.cjs",
    "check:audit": "npm audit",
    "fix:audit": "npm audit fix --force",
    "optimize:vite": "vite optimize",
    "build:perf": "vite build --mode production --debug",
    "analyze:bundle": "vite build --mode production && npx rollup-plugin-visualizer dist/stats.html",
    "check:unused-files": "ts-prune",
    "clean:git": "git clean -fdX",
    "unusedcheck": "depcheck .",
    "unusedcheck-json": "depcheck . --json",
    "unusedfix": "node unused-fix.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/react": "^10.46.0",
    "@statsig/react-bindings": "^3.32.3",
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gl-matrix": "^3.4.4",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "logrocket": "^12.1.0",
    "lucide-react": "^1.7.0",
    "mathjs": "^15.1.1",
    "ogl": "^1.0.11",
    "postprocessing": "^6.39.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-ga4": "^3.0.1",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "chalk": "^5.6.2",
    "chrome-launcher": "^1.2.1",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "lighthouse": "^13.0.3",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.46.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^0.19.8",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.1.2"
  }
}
